<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OtcDataService.ViewModels"
             x:Class="OtcDataService.Views.Settings.DatabaseSettingsView"
             x:DataType="vm:DatabaseSettingsViewModel">

  <StackPanel Spacing="20" MaxWidth="520">
    <TextBlock Text="Configure ODBC connection to the market database."
               Foreground="{StaticResource TextSecondaryBrush}"
               FontSize="13"
               TextWrapping="Wrap" />

    <StackPanel Spacing="14">
      <StackPanel Spacing="6">
        <TextBlock Text="DSN" Classes="formLabel" />
        <TextBox Text="{Binding OdbcDsn}" Classes="appInput" Watermark="e.g. market2" />
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="User ID" Classes="formLabel" />
        <TextBox Text="{Binding OdbcUserId}" Classes="appInput" />
      </StackPanel>

      <StackPanel Spacing="6">
        <TextBlock Text="Password" Classes="formLabel" />
        <TextBox Text="{Binding OdbcPassword}" Classes="appInput" PasswordChar="●" />
      </StackPanel>
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="Test Connection"
              Classes="primary"
              Command="{Binding TestConnectionCommand}" />
    </StackPanel>

    <TextBlock Text="{Binding StatusMessage}"
               Foreground="{StaticResource PrimaryBlueBrush}"
               FontSize="13"
               TextWrapping="Wrap"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </StackPanel>
</UserControl>
